# GitHub owner whose public repos are scanned for docs/
NEXT_PUBLIC_GITHUB_OWNER=

# Personal Access Token (fine-grained) with Contents + Metadata read-only
# Create at: https://github.com/settings/tokens?type=beta
GITHUB_PAT=

# Owner info (used on About page, Consulting section, social links)
NEXT_PUBLIC_OWNER_NAME=
NEXT_PUBLIC_OWNER_TITLE=
NEXT_PUBLIC_OWNER_EMAIL=
NEXT_PUBLIC_OWNER_PHONE=
NEXT_PUBLIC_OWNER_LINKEDIN=
